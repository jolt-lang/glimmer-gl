{:paths ["src"]

 ;; glimmer-gl is an extension of glimmer: the geometry/matrix/GL namespaces are
 ;; standalone, but glimmer-gl.gtk registers GL widgets (:gl-area, :scale) into
 ;; glimmer's widget registry, so glimmer is a dependency. Its GTK4/GLib native
 ;; libs merge in via the dependency walk (only used by glimmer-gl.gtk).
  :deps {jolt-lang/glimmer {:git/url "https://github.com/jolt-lang/glimmer"
                            :git/tag "v0.0.1"
                            :git/sha "4ede521b9dfac83873b3ff290dcc8fbeedb761e2"}}

 ;; OpenGL via the host. On macOS OpenGL ships as a framework; on Linux it's the
 ;; libGL shared object (mesa or the vendor driver). macOS note mirrors glimmer:
 ;; Chez's dlopen default search path does not include the framework dirs, so the
 ;; absolute framework executable path is listed first.
 :jolt/native [{:name "opengl"
                :darwin ["/System/Library/Frameworks/OpenGL.framework/OpenGL"
                         "/System/Library/Frameworks/OpenGL.framework/Versions/A/OpenGL"
                         "libGL.dylib"]
                :linux  ["libGL.so.1" "libGL.so"]}]

 ;; Native-GL geometry & matrix library for jolt, ported from thi.ng/geom's
 ;; platform-independent math onto jolt/Chez/FFI. See README.md.
 :aliases {:test {:extra-paths ["test"] :main-opts ["-m" "glimmer-gl.test-runner"]}}

 :tasks {test "joltc -M:test"}}
